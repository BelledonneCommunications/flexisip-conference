#!/bin/bash

# Set configuration directory permissions
chmod 750 @FLEXISIP_CONFIGURATION_FOLDER_INSTALL_LOCATION@

# If first installation then use rewrite-config from flexisip's configuration file to generate the correct new config file
if [ "$1" = "configure" ] && [ -z "$2" ] && [ -r "/etc/flexisip/flexisip.conf" ]; then
	mv @FLEXISIP_CONFIGURATION_FILE_INSTALL_LOCATION@ @FLEXISIP_CONFIGURATION_FILE_INSTALL_LOCATION@.default || :
	@FLEXISIP_CONFERENCE_EXECUTABLE_INSTALL_LOCATION@ -c "/etc/flexisip/flexisip.conf" --rewrite-config > @FLEXISIP_CONFIGURATION_FILE_INSTALL_LOCATION@ || :
fi

# Try to restart daemon after upgrade
systemctl try-restart @FLEXISIP_SERVICES@  >/dev/null 2>&1 || :
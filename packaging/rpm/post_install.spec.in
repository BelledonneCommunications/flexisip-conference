#  Set configuration directory permissions
chmod 750 @FLEXISIP_CONFIGURATION_FOLDER_INSTALL_LOCATION@ || :

# Create log folder
mkdir --parents @FLEXISIP_CONFERENCE_LOGDIR@ --mode 750 || :
semanage fcontext -a -t var_log_t '@FLEXISIP_CONFERENCE_LOGDIR@(/.*)?' 2>/dev/null || :
restorecon -R @FLEXISIP_CONFERENCE_LOGDIR@ || :

# First installation migrations
if [ "$1" -eq "1" ]; then

    # Use rewrite-config from Flexisip's configuration file to generate the correct new config file
    if [ -r "/etc/flexisip/flexisip.conf" ]; then
        mv @FLEXISIP_CONFIGURATION_FILE_INSTALL_LOCATION@ @FLEXISIP_CONFIGURATION_FILE_INSTALL_LOCATION@.default || :
        @FLEXISIP_CONFERENCE_EXECUTABLE_INSTALL_LOCATION@ -c "/etc/flexisip/flexisip.conf" --rewrite-config --remove-deprecated > @FLEXISIP_CONFIGURATION_FILE_INSTALL_LOCATION@ || :
    fi

    # Copy the "uuid" file from Flexisip
    if [ -r "/var/opt/belledonne-communications/lib/flexisip/uuid" ]; then
        mkdir -p @DEFAULT_LIB_DIR@ -m 750 || :
        cp "/var/opt/belledonne-communications/lib/flexisip/uuid" @DEFAULT_LIB_DIR@ || :
    fi

fi

%systemd_post @FLEXISIP_SERVICES@
/var/opt/belledonne-communications/flexisip-conference/log/*.log {
    size 500M
    rotate 7

    compress
    delaycompress

    nocreate
    missingok
    nodateext
    postrotate
        logfilename="$(basename $1)"
        pidfile="/var/run/${logfilename%.log}.pid"
        if [ -f "${pidfile}" ]; then
            kill -HUP $(cat ${pidfile})
        fi
    endscript
}
